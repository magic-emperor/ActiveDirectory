# ============================================================
# AD USER CREATOR - ENVIRONMENT CONFIGURATION
# Copy this to .env and fill in your actual values
# ============================================================

# ── ACTIVE DIRECTORY CONNECTION ──────────────────────────────
# Hostname or IP address of your Domain Controller
AD_SERVER=192.168.1.10

# Your AD domain (e.g., company.com)
AD_DOMAIN=company.com

# Base DN — derived from your domain
# For company.com → DC=company,DC=com
# For corp.local  → DC=corp,DC=local
AD_BASE_DN=DC=company,DC=com

# Admin credentials that have permission to create users
AD_ADMIN_USERNAME=administrator
AD_ADMIN_PASSWORD=YourAdminPasswordHere

# LDAP Port: 389 (plain) or 636 (LDAPS/TLS)
AD_PORT=389

# Use TLS? true/false (set true for production with port 636)
AD_USE_TLS=false

# ── DRY RUN MODE ─────────────────────────────────────────────
# Set to true to PRINT actions instead of actually creating users
# Perfect for testing without AD access
AD_DRY_RUN=true

# ── NAMING CONVENTION ────────────────────────────────────────
# Options: firstname.lastname | flastname | firstnamelastname
USERNAME_FORMAT=firstname.lastname

# ── GEMINI AI ────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── APP SETTINGS ─────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── HARDCODED AUTH (local use only) ──────────────────────────
# Comma-separated list of allowed usernames
APP_ALLOWED_USERS=admin,it_admin
# Simple token for API access (change this)
APP_SECRET_TOKEN=local-dev-token-change-me

# ── PASSWORD POLICY ──────────────────────────────────────────
# These should match your AD domain password policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true
# Force user to change password on first login
PASSWORD_MUST_CHANGE=true


